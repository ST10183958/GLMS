@model GLMS.Web.Models.ServiceRequest

@{
    ViewData["Title"] = "Delete Service Request";
}

<h2>Delete Service Request</h2>

<div class="alert alert-danger">
    Are you sure you want to delete this service request?
</div>

<div class="card mb-3">
    <div class="card-body">
        <p><strong>Description:</strong> @Model.Description</p>
        <p><strong>Cost USD:</strong> @Model.CostUsd</p>
        <p><strong>Cost ZAR:</strong> @Model.CostZar</p>
        <p><strong>Status:</strong> @Model.Status</p>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input asp-for="ContractId" type="hidden" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>