@model IEnumerable<GLMS.Web.Models.ServiceRequest>

@{
    ViewData["Title"] = "Service Requests";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Service Requests</h2>
    <a asp-action="Create" class="btn btn-success">Create New Service Request</a>
</div>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
    <tr>
        <th>Contract ID</th>
        <th>Description</th>
        <th>Cost (USD)</th>
        <th>Rate Used</th>
        <th>Cost (ZAR)</th>
        <th>Status</th>
        <th style="width:180px;">Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.ContractId</td>
            <td>@item.Description</td>
            <td>@item.CostUsd</td>
            <td>@item.ExchangeRateUsed</td>
            <td>@item.CostZar</td>
            <td>@item.Status</td>
            <td>
                    <a asp-action="Details" asp-route-id="@item.ServiceRequestId" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.ServiceRequestId" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>