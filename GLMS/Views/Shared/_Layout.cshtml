<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GLMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="glms-body">
    <header>
        <nav class="navbar navbar-expand-lg glms-topbar shadow-sm">
            <div class="container-fluid px-4">
                <a class="navbar-brand glms-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-main">GLMS</span>
                    <span class="brand-sub">TechMove Logistics</span>
                </a>

                <button class="navbar-toggler text-white border-white" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-4 me-auto">
                        <li class="nav-item">
                            <a class="nav-link glms-nav-link" asp-controller="Home" asp-action="Index">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link glms-nav-link" asp-controller="Clients" asp-action="Index">Clients</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link glms-nav-link" asp-controller="Contracts" asp-action="Index">Contracts</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link glms-nav-link" asp-controller="ServiceRequests" asp-action="Index">Service Requests</a>
                        </li>
                    </ul>

                    <form class="d-flex glms-search-bar" role="search">
                        <input class="form-control glms-search-input" type="search" placeholder="Search GLMS" />
                        <button class="btn glms-search-btn" type="submit">Search</button>
                    </form>
                </div>
            </div>
        </nav>

        <div class="glms-subbar">
            <div class="container-fluid px-4">
                <span>Enterprise Contract, Request and Logistics Management</span>
            </div>
        </div>
    </header>

    <main class="container-fluid px-4 py-4">
        @RenderBody()
    </main>

    <footer class="glms-footer mt-4">
        <div class="container-fluid px-4">
            <span>&copy; @DateTime.Now.Year GLMS - TechMove Logistics</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>