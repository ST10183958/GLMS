@model IEnumerable<GLMS.Web.Models.Contract>

@{
    ViewData["Title"] = "Contracts";
}

<div class="glms-page-header">
    <h2 class="glms-page-title">Contracts</h2>
    <a asp-action="Create" class="btn btn-primary">+ Create New Contract</a>
</div>

<form method="get" asp-action="Index" class="glms-filter-bar">
    <div class="row g-3">
        <div class="col-md-3">
            <label class="form-label glms-form-label">Start Date From</label>
            <input type="date" name="startDate" class="form-control" value="@Context.Request.Query["startDate"]" />
        </div>

        <div class="col-md-3">
            <label class="form-label glms-form-label">End Date To</label>
            <input type="date" name="endDate" class="form-control" value="@Context.Request.Query["endDate"]" />
        </div>

        <div class="col-md-3">
            <label class="form-label glms-form-label">Status</label>
            <select name="status" class="form-select">
                <option value="">-- All --</option>
                <option value="Draft">Draft</option>
                <option value="Active">Active</option>
                <option value="Expired">Expired</option>
                <option value="OnHold">On Hold</option>
            </select>
        </div>

        <div class="col-md-3 d-flex align-items-end">
            <button type="submit" class="btn btn-primary me-2">Search</button>
            <a asp-action="Index" class="btn btn-secondary">Clear</a>
        </div>
    </div>
</form>

<div class="glms-table-wrap">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>Client</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Status</th>
                <th>Service Level</th>
                <th>Agreement</th>
                <th style="width:260px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var statusClass = item.Status.ToString() switch
                {
                    "Draft" => "badge-draft",
                    "Active" => "badge-active",
                    "Expired" => "badge-expired",
                    "OnHold" => "badge-onhold",
                    _ => "badge-draft"
                };

                <tr>
                    <td><strong>@item.Client?.Name</strong></td>
                    <td>@item.StartDate.ToShortDateString()</td>
                    <td>@item.EndDate.ToShortDateString()</td>
                    <td><span class="badge-status @statusClass">@item.Status</span></td>
                    <td>@item.ServiceLevel</td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(item.SignedAgreementFilePath))
                        {
                            <a asp-action="DownloadAgreement" asp-route-id="@item.ContractId" class="glms-link">Download PDF</a>
                        }
                        else
                        {
                            <span class="text-muted">No file</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.ContractId" class="glms-link me-2">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.ContractId" class="glms-link me-2">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.ContractId" class="glms-link">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>