@model GLMS.Web.Models.Client

@{
    ViewData["Title"] = "Client Details";
}

<h2>Client Details</h2>

<div class="card">
    <div class="card-body">
        <p><strong>Name:</strong> @Model.Name</p>
        <p><strong>Contact Details:</strong> @Model.ContactDetails</p>
        <p><strong>Region:</strong> @Model.Region</p>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.ClientId" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>