@model IEnumerable<GLMS.Web.Models.Client>

@{
    ViewData["Title"] = "Clients";
}

<div class="glms-page-header">
    <h2 class="glms-page-title">Clients</h2>
    <a asp-action="Create" class="btn btn-primary">+ Create New Client</a>
</div>

<div class="glms-table-wrap">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>Name</th>
                <th>Contact Details</th>
                <th>Region</th>
                <th style="width: 220px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Name</strong></td>
                    <td>@item.ContactDetails</td>
                    <td>@item.Region</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.ClientId" class="glms-link me-2">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.ClientId" class="glms-link me-2">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.ClientId" class="glms-link">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>